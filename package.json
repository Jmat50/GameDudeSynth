{
  "name": "gamedudesynth",
  "version": "0.2.0",
  "description": "Game Boy-style MIDI synthesis with offline WAV export",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:bundle": "esbuild src-v2/index.ts --bundle --platform=browser --format=iife --global-name=GameDudeSynthV2 --outfile=public/gameboy-player.iife.js",
    "build:player-ui": "esbuild src-player/index.js --bundle --platform=browser --format=iife --outfile=public/gameboy-ui.iife.js",
    "verify:projectm": "node scripts/verify-projectm-vendor.js",
    "build:pages": "node scripts/verify-projectm-vendor.js && node scripts/build-github-pages.js",
    "build:demo": "npm run build:all && npm run demos:manifest && npm run build:pages",
    "build:all": "npm run build:bundle && npm run build:player-ui",
    "demos:manifest": "node scripts/generate-demos-manifest.js",
    "process:midi": "npx vite-node scripts/process-local-midi-v2.ts",
    "test:track-analysis": "npx vite-node scripts/test-track-analysis.ts",
    "test:preview-window": "npx vite-node scripts/test-preview-window.ts",
    "test:viz-controller": "node scripts/test-viz-controller.mjs",
    "presets:docs": "node scripts/generate-preset-docs.mjs",
    "verify:presets": "node scripts/verify-projectm-presets.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "node-web-audio-api": "^2.0.0",
    "playwright": "^1.50.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "howler": "^2.2.4",
    "lit": "^3.3.3"
  },
  "keywords": [
    "chiptune",
    "game-boy",
    "midi",
    "web-audio",
    "wav-export"
  ],
  "license": "MIT"
}
