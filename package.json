{
  "name": "gamedudesynth",
  "version": "0.2.0",
  "description": "Game Boy-style MIDI synthesis with offline WAV export",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:bundle": "esbuild src-v2/core/GameBoyPlayer.ts --bundle --platform=browser --format=iife --global-name=GameDudeSynthV2 --outfile=public/gameboy-player.iife.js",
    "process:midi": "npx vite-node scripts/process-local-midi-v2.ts",
    "test:track-analysis": "npx vite-node scripts/test-track-analysis.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.25.0",
    "node-web-audio-api": "^2.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@tonejs/midi": "^2.0.28"
  },
  "keywords": [
    "chiptune",
    "game-boy",
    "midi",
    "web-audio",
    "wav-export"
  ],
  "license": "MIT"
}
